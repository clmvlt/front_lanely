# Modèle de configuration d'environnement (à copier, ne contient pas de secret).
# Vite n'expose au navigateur que les variables préfixées par VITE_.
#
# Pour un override LOCAL non versionné, créez un fichier .env.<mode>.local
# (ex: .env.development.local) — ces fichiers sont ignorés par git.

# Environnement courant : dev | beta | demo | prod
VITE_APP_ENV=dev

# URL de base de l'API (absolue, sans slash final, sans préfixe /api ;
# l'API est servie sous le sous-domaine api.). Ex prod : https://api.lanely.fr
# En dev, appel direct à l'API (le CORS doit être autorisé côté backend).
VITE_API_BASE_URL=http://localhost:8080

# Client ID OAuth Google (Web) pour « Sign in with Google ».
# Les origines JavaScript autorisées doivent être déclarées dans la console Google.
# (Ce n'est pas un secret : le client secret ne transite jamais côté front.)
VITE_GOOGLE_CLIENT_ID=

# Jeton public Mapbox (carte) - meme valeur sur tous les environnements.
VITE_MAPBOX_TOKEN=pk....

# URL de base de l API ORS (routing, optimisation de tournees, geocodage BAN).
# API ouverte (sans authentification), meme valeur sur tous les environnements.
VITE_ORS_BASE_URL=https://ors.stack.bzh
