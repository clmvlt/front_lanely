# ---------------------------------------------------------------------------
# Environnements
#
# Les fichiers de config par environnement SONT versionnés (ils ne contiennent
# que des URLs d'API publiques, pas de secret) :
#   .env.development  .env.beta  .env.demo  .env.production  .env.example
#
# Les overrides LOCAUX (secrets, surcharges machine) ne le sont PAS :
.env
.env.*.local
.env.local
# ---------------------------------------------------------------------------

# Script de déploiement (contient des secrets SSH — ne jamais versionner)
# requirements.txt reste versionné (aucun secret)
deploy

